{
  "name": "play-console-package-verifier",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Generate a Google Play Console verification APK in your browser. Adds the required snippet and re-signs the APK with your existing keystore — no Android Studio or command-line tools needed.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc -b --noEmit"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "lucide-react": "^1.14.0",
    "node-forge": "^1.4.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
